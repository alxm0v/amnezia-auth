[Unit]
Description=AmneziaWG Captive Portal Auth Service
After=network.target

[Service]
User=amnezia-auth
WorkingDirectory={{ app_install_dir }}
ExecStart={{ app_install_dir }}/venv/bin/uvicorn main:app --host 0.0.0.0 --port {{ captive_portal_port }}
Restart=always
{% if actual_use_systemd_credentials | default(false) %}
LoadCredential=secret_key:/etc/amnezia-auth/credentials/secret_key
{% if auth_mode == 'oidc' %}
LoadCredential=oidc_client_secret:/etc/amnezia-auth/credentials/oidc_client_secret
{% endif %}
{% endif %}

[Install]
WantedBy=multi-user.target
