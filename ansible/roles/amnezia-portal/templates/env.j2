HOST=0.0.0.0
PORT={{ captive_portal_port }}
SECRET_KEY={{ 999999999999999999999999999 | random | to_uuid }}
AUTH_MODE={{ auth_mode }}
{% if auth_mode == 'oidc' %}
OIDC_CLIENT_ID={{ oidc_client_id }}
OIDC_CLIENT_SECRET={{ vault.oidc_client_secret | default(oidc_client_secret, true) }}
OIDC_DISCOVERY_URL={{ oidc_discovery_url }}
{% endif %}
VPN_INTERFACE={{ vpn_interface }}
INACTIVITY_TIMEOUT_SECONDS={{ inactivity_timeout_seconds | default('900') }}
MAX_SESSION_SECONDS={{ max_session_seconds | default('28800') }}
