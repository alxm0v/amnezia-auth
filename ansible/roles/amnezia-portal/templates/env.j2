HOST=0.0.0.0
PORT={{ captive_portal_port }}
SECRET_KEY={{ 999999999999999999999999999 | random | to_uuid }}
USE_REVERSE_PROXY={{ use_reverse_proxy | default('false') | lower }}
AUTH_MODE={{ auth_mode }}
{% if auth_mode == 'oidc' %}
OIDC_CLIENT_ID={{ oidc_client_id }}
OIDC_CLIENT_SECRET={{ vault.oidc_client_secret | default(oidc_client_secret, true) }}
OIDC_DISCOVERY_URL={{ oidc_discovery_url }}
{% endif %}
TOTP_ISSUER_NAME="{{ totp_issuer_name | default('AmneziaWG Portal') }}"
TOTP_ACCOUNT_NAME_TEMPLATE="{{ totp_account_name_template | default('VPN ({peer_name} - {peer_ip})') }}"
VPN_INTERFACE={{ vpn_interface }}
INACTIVITY_TIMEOUT_SECONDS={{ inactivity_timeout_seconds | default('900') }}
MAX_SESSION_SECONDS={{ max_session_seconds | default('28800') }}
HANDSHAKE_SILENCE_THRESHOLD_SECONDS={{ logging_settings.handshake_silence_threshold_seconds | default('3600') }}
ENABLE_AUDIT_LOGGING={{ logging_settings.enable_audit_logging | default('true') }}
TOTP_SECRETS_FILE="{{ app_install_dir }}/totp_secrets.json"
HANDSHAKES_DB_PATH="{{ app_install_dir }}/handshakes.db"
SESSIONS_DB_PATH="{{ app_install_dir }}/sessions.db"
