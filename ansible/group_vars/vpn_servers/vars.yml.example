---
# Standard variables can go here
# Subnets/IPs allowed BEFORE authorization (e.g. OIDC Provider, DNS)
preauth_allowed_subnets: []
captive_portal_port: 8000
# Authentication Mode (can be 'totp' or 'oidc')
auth_mode: "totp"

# Network Audit Logging
logging_settings:
  enable_audit_logging: true
  enable_kernel_connection_logging: false
  handshake_silence_threshold_seconds: 3600

# VPN Network Settings
vpn_port: 5281

# Allowed Subnets to route through the VPN
allowed_subnets:
  - "172.31.0.0/16"

# Granular iptables access control
iptables_default_policy: "DROP"
iptables_global_rules:
  allow:
    - "172.31.0.0/16"
  deny: []

# Custom AmneziaWG Obfuscation Parameters
awg_obfuscation_settings: |
  Jc = 120
  Jmin = 50
  Jmax = 100
  S1 = 15
  S2 = 25
  S3 = 15
  S4 = 25
  H1 = 123456789
  H2 = 987654321
  H3 = 111222333
  H4 = 444555666
  I1 = <b 0x1a2d>
  I2 = <b 0x1a2d>
  I3 = <b 0x1a2d>
  I4 = <b 0x1a2d>
  I5 = <b 0x1a2d>

# The public IP or domain name of this VPN server
vpn_public_ip_or_domain: "1.2.3.4"

# Fail2Ban Configuration
fail2ban:
  portal_maxretry: 10
  portal_findtime: 60
  portal_bantime: 3600
  sshd_maxretry: 5
  sshd_bantime: 3600

# OIDC Configuration
oidc_client_id: "vpn-gateway"
oidc_discovery_url: "https://REPLACE_ME_AUTH_DOMAIN/.well-known/openid-configuration"
